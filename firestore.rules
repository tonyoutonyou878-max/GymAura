rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // START: Permissive rules for debugging
    
    // Allow any authenticated user to read/write any document in the 'users' collection
    match /users/{userId} {
      allow read, write: if request.auth != null;
    }
    
    // Allow any authenticated user to read/write orders (for now)
    match /orders/{orderId} {
      allow read, write: if request.auth != null;
    }
    
    // Allow public read for products, auth write
    match /products/{productId} {
      allow read: if true;
      allow write: if request.auth != null;
    }

    // Default catch-all: Allow authenticated users to access everything else
    match /{document=**} {
      allow read, write: if request.auth != null;
    }
    // END: Permissive rules for debugging
  }
}
